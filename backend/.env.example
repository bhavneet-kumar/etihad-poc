# Google AI (receipt OCR)
GEMINI_API_KEY=
# Model must support generateContent + vision (see Google AI Studio / ListModels).
# Default in code is gemini-2.0-flash if unset.
GEMINI_OCR_MODEL=gemini-2.0-flash

# PostgreSQL (required for npm run start — must match a running Postgres)
# Repo root docker-compose: docker compose up -d postgres
# Example matching compose defaults: postgresql://claimuser:claimpass@localhost:5432/claims_db
DATABASE_URL=postgresql://user:password@localhost:5432/claims_db
# Optional: only used when DATABASE_URL is unset. Do not set PGHOST=localhost in Docker if DATABASE_URL points at the postgres service.
# PGHOST=

# JWT (change JWT_SECRET in production)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=1d

# Do not set NODE_TLS_REJECT_UNAUTHORIZED=0 in production (disables TLS verification; triggers Node warnings).
